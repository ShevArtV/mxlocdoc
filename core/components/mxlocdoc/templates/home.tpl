<div id="mxlocdoc-app" class="mxlocdoc-app">
    <div class="mxlocdoc-shell" data-mxlocdoc-shell>
        <aside class="mxlocdoc-sidebar" data-mxlocdoc-sidebar>
            <div class="mxlocdoc-sidebar__header">
                <div class="mxlocdoc-sidebar__title">[[%mxlocdoc]]</div>
                <button class="mxlocdoc-icon-button mxlocdoc-sidebar__close" type="button" data-mxlocdoc-sidebar-close title="[[%mxlocdoc_close_navigation]]" aria-label="[[%mxlocdoc_close_navigation]]">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <nav class="mxlocdoc-nav" data-mxlocdoc-nav aria-label="[[%mxlocdoc_navigation]]"></nav>
        </aside>

        <div class="mxlocdoc-main">
            <header class="mxlocdoc-topbar">
                <button class="mxlocdoc-icon-button mxlocdoc-topbar__menu" type="button" data-mxlocdoc-sidebar-open title="[[%mxlocdoc_open_navigation]]" aria-label="[[%mxlocdoc_open_navigation]]">
                    <span aria-hidden="true"></span>
                </button>
                <div class="mxlocdoc-search" role="search">
                    <input type="search" data-mxlocdoc-search placeholder="[[%mxlocdoc_search_placeholder]]" autocomplete="off">
                    <div class="mxlocdoc-search__hint" data-mxlocdoc-search-hint>[[%mxlocdoc_search_coming_soon]]</div>
                </div>
            </header>

            <div class="mxlocdoc-content-grid">
                <main class="mxlocdoc-document-panel">
                    <div class="mxlocdoc-state" data-mxlocdoc-state>[[%mxlocdoc_loading]]</div>
                    <div class="mxlocdoc-breadcrumbs" data-mxlocdoc-breadcrumbs aria-label="[[%mxlocdoc_breadcrumbs]]"></div>
                    <article class="mxlocdoc-article" data-mxlocdoc-article></article>
                    <div class="mxlocdoc-warnings" data-mxlocdoc-warnings></div>
                </main>

                <aside class="mxlocdoc-toc" data-mxlocdoc-toc aria-label="[[%mxlocdoc_toc]]">
                    <div class="mxlocdoc-toc__title">[[%mxlocdoc_toc]]</div>
                    <nav data-mxlocdoc-toc-list></nav>
                </aside>
            </div>
        </div>
    </div>
</div>
